{
  "name": "opengis",
  "version": "0.2.0",
  "description": "AI-powered GIS desktop application — natural language driven geospatial analysis",
  "main": "out/electron/main.js",
  "author": "OpenGIS Contributors",
  "license": "MIT",
  "private": true,
  "scripts": {
    "dev": "vite",
    "dev:electron": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "lint": "eslint . --ext .ts,.tsx",
    "lint:fix": "eslint . --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"electron/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "postinstall": "electron-builder install-app-deps",
    "setup:python": "node python-backend/setup-python.mjs",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "dist:win": "electron-builder --win",
    "dist:mac": "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "dependencies": {
    "@deck.gl/core": "^9.0.36",
    "@deck.gl/geo-layers": "^9.0.36",
    "@deck.gl/layers": "^9.0.36",
    "@deck.gl/mapbox": "^9.0.36",
    "@loaders.gl/3d-tiles": "^4.2.3",
    "@loaders.gl/core": "^4.2.3",
    "@loaders.gl/las": "^4.2.3",
    "@loaders.gl/tiles": "^4.2.3",
    "@monaco-editor/react": "^4.7.0",
    "@tmcw/togeojson": "^7.1.2",
    "ai": "^3.4.7",
    "clsx": "^2.1.1",
    "geotiff": "^2.1.3",
    "katex": "^0.17.0",
    "lucide-react": "^0.447.0",
    "maplibre-gl": "^4.7.1",
    "monaco-editor": "^0.55.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.0.1",
    "react-resizable-panels": "^2.1.4",
    "react-syntax-highlighter": "^15.5.0",
    "react-virtuoso": "^4.18.10",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "shapefile": "^0.6.6",
    "tailwind-merge": "^2.5.3",
    "uuid": "^10.0.0",
    "zod": "^3.25.76",
    "zustand": "^4.5.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.1",
    "@types/react-syntax-highlighter": "^15.5.13",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^30.5.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.12.0",
    "eslint-plugin-react-hooks": "^5.1.0-rc.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.8.1",
    "vite": "^5.4.8",
    "vitest": "^2.1.2"
  }
}
